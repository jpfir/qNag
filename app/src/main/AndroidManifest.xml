<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Android 13+ runtime notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Required to show the "Allow unrestricted battery usage" dialog for this app.
        The app only opens the dialog when the user explicitly taps the button in Settings.
        This permission is acceptable for monitoring/alerting apps (Nagios monitoring qualifies).
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Foreground service (optional "Keep monitoring active" feature, user-controlled) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        Android 14+ requires a specific foreground service type permission.
        dataSync is the closest type for a monitoring/data-fetching service.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QNag">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QNag"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Optional foreground service for "Keep monitoring active".
            foregroundServiceType="dataSync" satisfies the Android 14+ type requirement.
        -->
        <service
            android:name=".service.NagiosMonitoringService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>