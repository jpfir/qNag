<?xml version="1.0" encoding="utf-8"?>
<!--
    qNag launcher icon background.
    Vertical three-stop gradient: bright green → yellow/olive → orange/yellow.
    Fills the full 108×108 adaptive-icon canvas so any launcher crop shape
    (circle, rounded square, squircle) shows the gradient correctly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="108"
                android:startX="54"
                android:startY="0"
                android:type="linear">
                <item android:color="#FF75D83A" android:offset="0.0" />
                <item android:color="#FFB6C83A" android:offset="0.5" />
                <item android:color="#FFF5A000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
