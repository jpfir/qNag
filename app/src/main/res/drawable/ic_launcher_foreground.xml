<?xml version="1.0" encoding="utf-8"?>
<!--
    qNag launcher icon foreground — a bold white capital "Q".

    Canvas: 108×108 dp (adaptive icon standard).
    Safe zone: 36 dp radius from canvas centre (54, 54).  All shapes stay within.

    Q design:
      Bowl — donut ring, centre (54, 52), outer R=30, inner r=19.
             evenOdd fill: two clockwise circles produce the ring shape.
             Height 60 dp ≈ 56 % of the 108 dp canvas (target 55-65 %).

      Tail — 20×9 dp bar, rotated 45 °, centred at (68, 70).
             Starts inside the counter (hole), crosses the ring wall, and
             extends ~3 dp outside the outer ring at the 4-o'clock position.
             The white tail merges with the white ring to form the Q tail.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Q bowl: even-odd pair of clockwise circles creates a solid ring -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M 54,22
            A 30,30 0 1 1 53.999,22 Z
            M 54,33
            A 19,19 0 1 1 53.999,33 Z" />

    <!-- Q tail: thick diagonal bar at the 4-o'clock position of the ring -->
    <group
        android:pivotX="68"
        android:pivotY="70"
        android:rotation="45">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M58,65.5 h20 v9 h-20 z" />
    </group>

</vector>
