<?xml version="1.0" encoding="utf-8"?>
<!--
    AppWidget provider metadata for the qNag problem list widget (4×2 or larger).
    updatePeriodMillis="0": Glance manages its own updates triggered by the polling cycle.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="220dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:initialLayout="@layout/widget_initial_layout"
    android:updatePeriodMillis="0" />
